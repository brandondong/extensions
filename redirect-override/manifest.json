{
  "manifest_version": 3,
  "name": "Custom redirects",
  "version": "0.1",
  "description": "Static redirect overrides.",
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.x.com/*"
  ]
}